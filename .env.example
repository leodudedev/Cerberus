# Telegram bot token da @BotFather
TELEGRAM_BOT_TOKEN=

# Chat id autorizzato (solo questo puo comandare le sessioni)
TELEGRAM_CHAT_ID=

# Chat/gruppi extra consentiti come target di .mycli.json e come sorgenti comandi (csv)
TELEGRAM_ALLOWED_CHATS=

# Porta del daemon HTTP (bind solo su 127.0.0.1)
PORT=8787
