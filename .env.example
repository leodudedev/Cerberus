# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Authorized chat id (only this one can drive the sessions)
TELEGRAM_CHAT_ID=

# Extra chats/groups allowed as .cerberus.json targets and as command sources (csv)
TELEGRAM_ALLOWED_CHATS=

# HTTP daemon port (binds to 127.0.0.1 only)
PORT=8899

# Telegram message language: "en" by default, "it" for Italian
CERBERUS_LANG=en
