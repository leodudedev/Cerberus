{
  "name": "cerberus",
  "version": "0.1.0",
  "description": "Remote control for Claude Code and GitHub Copilot CLI sessions from your phone, via Telegram and tmux",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "cerberus": "./src/bin/cerberus.ts"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch src/daemon/index.ts",
    "start": "node --env-file=.env src/daemon/index.ts",
    "typecheck": "tsc"
  },
  "dependencies": {
    "grammy": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
