{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "__CERBERUS_DIR__/hooks/copilot-notify.sh",
        "timeoutSec": 5
      }
    ],
    "notification": [
      {
        "type": "command",
        "bash": "__CERBERUS_DIR__/hooks/copilot-notify.sh",
        "timeoutSec": 5
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "__CERBERUS_DIR__/hooks/copilot-notify.sh",
        "timeoutSec": 5
      }
    ]
  }
}
